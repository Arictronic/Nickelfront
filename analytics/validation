def validate_schema(df: pl.DataFrame) -> bool:
    """Проверка наличия всех необходимых колонок и их типов"""
    required_columns = {
        "patent_id": pl.Utf8,
        "title": pl.Utf8,
        "date": pl.Utf8,   # позже преобразуем в Date
        "category": pl.Utf8,
        "applicant": pl.Utf8,
        "country": pl.Utf8
    }
    
    for col, expected_type in required_columns.items():
        if col not in df.columns:
            raise ValueError(f"Отсутствует обязательная колонка: {col}")
        if df[col].dtype != expected_type:
            # Приводим к нужному типу, если возможно
            try:
                df = df.with_columns(pl.col(col).cast(expected_type))
            except:
                raise TypeError(f"Колонка {col} имеет тип {df[col].dtype}, ожидался {expected_type}")
    return True

def validate_dates(df: pl.DataFrame) -> pl.DataFrame:
    """Преобразование дат и проверка корректности"""
    df = df.with_columns(
        pl.col("date").str.strptime(pl.Date, "%Y-%m-%d", strict=False).alias("date_parsed")
    )
    # Проверяем, что все даты распарсились
    invalid_dates = df.filter(pl.col("date_parsed").is_null()).shape[0]
    if invalid_dates > 0:
        print(f"Предупреждение: {invalid_dates} записей с некорректной датой")
    return df.drop("date").rename({"date_parsed": "date"})

def validate_patent_id(df: pl.DataFrame) -> pl.DataFrame:
    """Проверка формата patent_id (например, начинается с двух букв и 8 цифр)"""
    pattern = r"^[A-Z]{2}\d{8}$"
    df = df.with_columns(
        pl.col("patent_id").str.contains(pattern).alias("valid_patent_id")
    )
    invalid = df.filter(~pl.col("valid_patent_id")).shape[0]
    if invalid > 0:
        print(f"Предупреждение: {invalid} записей с некорректным patent_id")
    return df

def validate_country(df: pl.DataFrame) -> pl.DataFrame:
    """Проверка, что страна представлена двухбуквенным кодом"""
    # Оставляем только строки, где country соответствует ISO 3166-1 alpha-2
    # Для простоты проверяем только длину 2 и отсутствие цифр
    df = df.with_columns(
        pl.col("country").str.len().alias("country_len"),
        pl.col("country").str.contains(r"^[A-Z]{2}$").alias("valid_country")
    )
    invalid = df.filter(~pl.col("valid_country")).shape[0]
    if invalid > 0:
        print(f"Предупреждение: {invalid} записей с некорректным кодом страны")
    return df.drop(["country_len", "valid_country"])

# Применяем валидацию
df_validated = validate_schema(df_raw)
df_validated = validate_dates(df_validated)
df_validated = validate_patent_id(df_validated)
df_validated = validate_country(df_validated)

print("\nПосле валидации (df_validated):")
