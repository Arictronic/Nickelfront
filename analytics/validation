df_no_duplicates = df_validated.unique(subset=["patent_id"], keep="first")

print(f"Размер после удаления дубликатов: {df_no_duplicates.shape[0]} записей")

def check_completeness(df: pl.DataFrame) -> pl.DataFrame:
    """Возвращает DataFrame с процентами заполненности по колонкам"""
    total_rows = df.shape[0]
    completeness = {}
    for col in df.columns:
        non_null = df[col].null_count()
        completeness[col] = (total_rows - non_null) / total_rows * 100
    completeness_df = pl.DataFrame({
        "column": list(completeness.keys()),
        "completeness_%": list(completeness.values())
    })
    return completeness_df

completeness_df = check_completeness(df_no_duplicates)
print("\nПолнота данных:")
print(completeness_df)

# Фильтрация записей с критическими пропусками (например, отсутствие patent_id)
critical_missing = df_no_duplicates.filter(pl.col("patent_id").is_null())
if critical_missing.shape[0] > 0:
    print(f"Обнаружено {critical_missing.shape[0]} записей без patent_id – они будут удалены")
    df_final = df_no_duplicates.filter(pl.col("patent_id").is_not_null())
else:
    df_final = df_no_duplicates

# Дополнительно: можно заполнить пропуски в других колонках значением "Unknown"
df_final = df_final.with_columns(
    pl.col("title").fill_null("Unknown"),
    pl.col("category").fill_null("Other"),
    pl.col("applicant").fill_null("Unknown"),
    pl.col("country").fill_null("Unknown")
)
