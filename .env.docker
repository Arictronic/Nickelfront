# =============================================================================
# Nickelfront Docker Environment Variables
# =============================================================================
# Этот файл используется для развёртывания в Docker
# Все сервисы работают в одной сети и общаются по именам контейнеров

# -----------------------------------------------------------------------------
# Database (внутренний DNS Docker)
# -----------------------------------------------------------------------------
DATABASE_URL=postgresql+asyncpg://postgres:postgres@postgres:5432/nickelfront

# -----------------------------------------------------------------------------
# Redis (внутренний DNS Docker)
# -----------------------------------------------------------------------------
REDIS_URL=redis://redis:6379/0

# -----------------------------------------------------------------------------
# Celery
# -----------------------------------------------------------------------------
CELERY_BROKER_URL=redis://redis:6379/0
CELERY_RESULT_BACKEND=redis://redis:6379/1
CELERY_BEAT_SCHEDULE_FILENAME=/app/celerybeat-schedule
PARSE_SCHEDULE_INTERVAL=60
PARSE_LIMIT_PER_RUN=50
PARSE_QUERIES=["nickel-based alloys","superalloys","heat resistant alloys"]

# -----------------------------------------------------------------------------
# API Settings
# -----------------------------------------------------------------------------
API_HOST=0.0.0.0
API_PORT=8001
DEBUG=false

# -----------------------------------------------------------------------------
# Security
# -----------------------------------------------------------------------------
SECRET_KEY=nickelfront-secret-key-change-in-production-abc123xyz
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30

# -----------------------------------------------------------------------------
# CORS (разрешаем все домены для работы через nginx)
# -----------------------------------------------------------------------------
CORS_ORIGINS=["*"]

# -----------------------------------------------------------------------------
# Vector Search
# -----------------------------------------------------------------------------
CHROMA_DB_PATH=/app/chroma_db
EMBEDDING_MODEL=all-MiniLM-L6-v2
EMBEDDING_DIM=384
EMBEDDING_LOCAL_ONLY=false
EMBEDDING_CACHE_DIR=/app/models

# -----------------------------------------------------------------------------
# Logging
# -----------------------------------------------------------------------------
LOG_LEVEL=INFO
LOG_FILE=/app/logs/app.log

# -----------------------------------------------------------------------------
# Frontend (пустой = относительный путь /api/v1)
# -----------------------------------------------------------------------------
VITE_API_URL=

# -----------------------------------------------------------------------------
# Flower (мониторинг Celery)
# -----------------------------------------------------------------------------
FLOWER_PORT=5555
FLOWER_UNAUTHENTICATED_API=true
