# =============================================================================
# Nickelfront Environment Variables
# =============================================================================
# Скопируйте этот файл в .env и заполните значениями
# cp .env.example .env

# -----------------------------------------------------------------------------
# Database
# -----------------------------------------------------------------------------
# PostgreSQL подключение
# Формат: postgresql+asyncpg://<user>:<password>@<host>:<port>/<database>
DATABASE_URL=postgresql+asyncpg://user:password@localhost:5433/nickelfront

# -----------------------------------------------------------------------------
# Redis
# -----------------------------------------------------------------------------
# Redis подключение для Celery
# Формат: redis://<host>:<port>/<db>
REDIS_URL=redis://localhost:6380/0

# -----------------------------------------------------------------------------
# Celery
# -----------------------------------------------------------------------------
# Broker URL для Celery (обычно Redis)
CELERY_BROKER_URL=redis://localhost:6379/0

# Backend для результатов Celery задач
CELERY_RESULT_BACKEND=redis://localhost:6379/1

# Файл для хранения расписания Celery Beat
CELERY_BEAT_SCHEDULE_FILENAME=./celerybeat-schedule

# Интервал парсинга по расписанию (в минутах)
PARSE_SCHEDULE_INTERVAL=60

# Лимит статей на один запуск парсинга
PARSE_LIMIT_PER_RUN=50

# Поисковые запросы для периодического парсинга (через запятую)
PARSE_QUERIES=nickel-based alloys,superalloys,heat resistant alloys

# -----------------------------------------------------------------------------
# API Settings
# -----------------------------------------------------------------------------
# Хост для запуска сервера
API_HOST=0.0.0.0

# Порт для запуска сервера
API_PORT=8001

# Режим отладки (true/false)
DEBUG=true

# -----------------------------------------------------------------------------
# Security
# -----------------------------------------------------------------------------
# Секретный ключ для JWT токенов
# Рекомендуется использовать случайную строку длиной 32+ символа
# Для генерации: python -c "import secrets; print(secrets.token_urlsafe(32))"
SECRET_KEY=your-secret-key-here

# Алгоритм шифрования JWT (не менять)
ALGORITHM=HS256

# Время жизни access токена (в минутах)
ACCESS_TOKEN_EXPIRE_MINUTES=30

# -----------------------------------------------------------------------------
# CORS
# -----------------------------------------------------------------------------
# Разрешенные origin для CORS (через запятую)
CORS_ORIGINS=http://localhost:3000,http://localhost:5173

# -----------------------------------------------------------------------------
# Vector Search
# -----------------------------------------------------------------------------
# Путь к ChromaDB для векторного поиска
CHROMA_DB_PATH=./chroma_db

# Модель для генерации эмбеддингов
EMBEDDING_MODEL=all-MiniLM-L6-v2

# Размерность эмбеддингов (зависит от модели)
# all-MiniLM-L6-v2: 384
# all-mpnet-base-v2: 768
EMBEDDING_DIM=384

# -----------------------------------------------------------------------------
# Logging
# -----------------------------------------------------------------------------
# Уровень логирования (DEBUG, INFO, WARNING, ERROR, CRITICAL)
LOG_LEVEL=INFO

# Путь к файлу логов
LOG_FILE=./logs/app.log

# -----------------------------------------------------------------------------
# Frontend (для Docker)
# -----------------------------------------------------------------------------
# URL backend API для frontend
VITE_API_URL=http://localhost:8001/api/v1

# -----------------------------------------------------------------------------
# Flower (мониторинг Celery)
# -----------------------------------------------------------------------------
# Порт для Flower
FLOWER_PORT=5555

# -----------------------------------------------------------------------------
# Примеры для production
# -----------------------------------------------------------------------------
# DATABASE_URL=postgresql+asyncpg://user:strong_password@db.example.com:5432/nickelfront
# REDIS_URL=redis://redis.example.com:6379/0
# SECRET_KEY=super-secret-key-from-environment-variable
# DEBUG=false
# CORS_ORIGINS=https://nickelfront.com
